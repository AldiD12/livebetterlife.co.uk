{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "./dist-scripts",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/utils/*.ts"],
  "exclude": ["node_modules"]
}
